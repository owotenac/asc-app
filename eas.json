{
  "cli": {
    "version": ">= 16.26.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_READONLY": "true"
      }      
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_READONLY": "false"
      }            
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_READONLY": "true"
      }               
    }
  },
  "submit": {
    "production": {}
  }
}
